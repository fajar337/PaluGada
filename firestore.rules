rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "mustofafajar733@gmail.com";
    }

    function validOrderCreate() {
      return request.resource.data.keys().hasAll([
        "id",
        "buyer",
        "items",
        "total",
        "status",
        "createdAt"
      ])
      && request.resource.data.id == request.resource.id
      && request.resource.data.status == "Menunggu Pembayaran";
    }

    function validReviewCreate() {
      return request.resource.data.keys().hasAll([
        "id",
        "productId",
        "name",
        "rating",
        "message",
        "createdAt"
      ])
      && request.resource.data.id == request.resource.id
      && request.resource.data.rating is number
      && request.resource.data.rating >= 1
      && request.resource.data.rating <= 5;
    }

    function validProductRequestCreate() {
      return request.resource.data.keys().hasAll([
        "id",
        "name",
        "wa",
        "appName",
        "status",
        "createdAt"
      ])
      && request.resource.data.id == request.resource.id
      && request.resource.data.status == "Baru";
    }

    function publicOrderVerificationUpdate() {
      return resource.data.status == "Menunggu Pembayaran"
        && request.resource.data.status == "Menunggu Verifikasi"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status"]);
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if validReviewCreate();
      allow update, delete: if isAdmin();
    }

    match /productRequests/{requestId} {
      allow create: if validProductRequestCreate();
      allow read, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if validOrderCreate();
      allow update: if isAdmin() || publicOrderVerificationUpdate();
      allow delete: if isAdmin();
    }

    match /resellers/{resellerId} {
      allow read, write: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
